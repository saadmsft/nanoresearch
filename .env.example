# =========================================================================
# Azure AI Foundry / Azure OpenAI — used for every non-planner agent.
# Authentication is via Azure AD (DefaultAzureCredential). No API keys.
# Run `az login` before starting NanoResearch.
# =========================================================================
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Optional: override the AAD scope (default is correct for Azure OpenAI / Foundry)
# AZURE_OPENAI_TOKEN_SCOPE=https://cognitiveservices.azure.com/.default

# =========================================================================
# Local planner — Qwen2.5-7B-Instruct
# =========================================================================
# Either a HuggingFace repo id or an absolute path to a local snapshot
QWEN_MODEL_PATH=Qwen/Qwen2.5-7B-Instruct

# Where to keep per-user LoRA adapters (one subdir per user_id)
LORA_ADAPTERS_DIR=./data/users

# Device for the local model. "mps" on Apple Silicon, "cuda" elsewhere, "cpu" as last resort.
LOCAL_MODEL_DEVICE=mps

# Cap planner generation at this many new tokens (planning JSON shouldn't exceed this)
PLANNER_MAX_NEW_TOKENS=1024

# =========================================================================
# Storage / runs
# =========================================================================
RUNS_DIR=./runs
DATA_DIR=./data
LOG_LEVEL=INFO
